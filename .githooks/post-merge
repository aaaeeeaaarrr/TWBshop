#!/bin/sh
# Runs automatically after every git pull.
# Always syncs latest secrets, SSH key, and global CLAUDE.md silently.
# If secrets.py is missing entirely, shows the full setup reminder instead.

if [ ! -f "secrets.py" ]; then
    echo ""
    echo "┌─────────────────────────────────────────────┐"
    echo "│  NEW MACHINE or secrets missing!            │"
    echo "│                                             │"
    echo "│  Just say:  pull                            │"
    echo "│  (Claude Code handles the rest)             │"
    echo "│                                             │"
    echo "└─────────────────────────────────────────────┘"
    echo ""
else
    python bootstrap.py --sync
fi
